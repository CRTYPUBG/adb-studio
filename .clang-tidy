Checks: >
  bugprone-*,clang-analyzer-*,cppcoreguidelines-*,modernize-*,performance-*,portability-*,readability-*,
  -cppcoreguidelines-avoid-magic-numbers,-modernize-use-trailing-return-type,
  -readability-magic-numbers,-readability-identifier-length
WarningsAsErrors: '*'
HeaderFilterRegex: '^(apps|core|engine|plugins|sdk|tests)/'
