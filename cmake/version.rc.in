#include <windows.h>

IDI_ADB_STUDIO_ICON ICON DISCARDABLE "@ADB_STUDIO_ICON_RC_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@ADB_STUDIO_BUILD@
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@ADB_STUDIO_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "ADB Studio Community\0"
      VALUE "FileDescription", "ADB Studio\0"
      VALUE "FileVersion", "@PROJECT_VERSION@.@ADB_STUDIO_BUILD@\0"
      VALUE "InternalName", "adb-studio\0"
      VALUE "OriginalFilename", "adb-studio.exe\0"
      VALUE "ProductName", "ADB Studio\0"
      VALUE "ProductVersion", "@PROJECT_VERSION@.@ADB_STUDIO_BUILD@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
